{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "windows-default",
      "displayName": "Windows x64 default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Windows"
      }
    },
    {
      "name": "linux-default",
      "displayName": "Linux default",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build",
      "condition": {
        "type": "equals",
        "lhs": "${hostSystemName}",
        "rhs": "Linux"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "windows-debug",
      "configurePreset": "windows-default",
      "configuration": "Debug"
    },
    {
      "name": "windows-release",
      "configurePreset": "windows-default",
      "configuration": "Release"
    },
    {
      "name": "linux-debug",
      "configurePreset": "linux-default",
      "configuration": "Debug"
    },
    {
      "name": "linux-release",
      "configurePreset": "linux-default",
      "configuration": "Release"
    }
  ]
}
