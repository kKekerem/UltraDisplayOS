# UltraDisplay OS Appliance Config for Buildroot

# Architecture
BR2_x86_64=y
BR2_x86_corei7=y

# Toolchain
BR2_TOOLCHAIN_BUILDROOT_GLIBC=y
BR2_TOOLCHAIN_BUILDROOT_CXX=y

# Kernel
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_CUSTOM_VERSION=y
BR2_LINUX_KERNEL_CUSTOM_VERSION_VALUE="6.6.20"
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="x86_64"

# System setup
BR2_TARGET_GENERIC_HOSTNAME="ultradisplay"
BR2_TARGET_GENERIC_ISSUE="UltraDisplay OS"
BR2_INIT_BUSYBOX=y
# We manage device nodes manually for absolute minimal overhead
BR2_ROOTFS_DEVICE_CREATION_STATIC=y

# Bootloader
BR2_TARGET_GRUB2=y
BR2_TARGET_GRUB2_X86_64_EFI=y

# Packages
BR2_PACKAGE_BUSYBOX=y
BR2_PACKAGE_BUSYBOX_SHOW_OTHERS=y

# Networking
BR2_PACKAGE_IPROUTE2=y
BR2_PACKAGE_ETHTOOL=y
BR2_PACKAGE_IW=y
BR2_PACKAGE_WPA_SUPPLICANT=y
BR2_PACKAGE_WPA_SUPPLICANT_NL80211=y
BR2_PACKAGE_AVAHI=y
BR2_PACKAGE_AVAHI_DAEMON=y
BR2_PACKAGE_AVAHI_LIBDNSSD_COMPATIBILITY=y

# Hardware and DRM
BR2_PACKAGE_LIBDRM=y
BR2_PACKAGE_LIBVA=y
BR2_PACKAGE_LIBVA_INTEL_DRIVER=y
BR2_PACKAGE_LIBVA_UTILS=y
BR2_PACKAGE_MESA3D=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_IRIS=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_RADEONSI=y
BR2_PACKAGE_MESA3D_OPENGL_EGL=y
BR2_PACKAGE_MESA3D_OPENGL_ES=y

# Input
BR2_PACKAGE_LIBEVDEV=y

# Audio
BR2_PACKAGE_ALSA_LIB=y
BR2_PACKAGE_ALSA_UTILS=y

# Target Filesystem
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS_XZ=y
# CPIO initrd for live ISO boot
BR2_TARGET_ROOTFS_CPIO=y
BR2_TARGET_ROOTFS_CPIO_XZ=y
# NOTE: We do NOT use Buildroot's ISO9660 target. Our post-image.sh
# builds a proper hybrid bootable ISO using xorriso + GRUB.

# Custom rootfs overlay (for /init, /etc, /firmware)
BR2_ROOTFS_OVERLAY="board/ultradisplay/rootfs_overlay"
BR2_ROOTFS_POST_IMAGE_SCRIPT="board/ultradisplay/post-image.sh"
